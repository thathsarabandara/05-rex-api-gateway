NODE_ENV=production
PORT=3001
LOG_LEVEL=info
AUTH_SERVER_URL=http://host.docker.internal:8000
IDENTITY_SERVER_URL=http://host.docker.internal:8001
WEB_DASHBOARD_URL=http://localhost:5174
ALLOWED_ORIGINS=http://localhost:5174
JWT_AUTH_SECRET=your_auth_secret_key_here
JWT_IDENTITY_SECRET=your_identity_secret_key_here
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
REQUEST_TIMEOUT=30000

# Central Database Configurations
MYSQL_ROOT_PASSWORD=rex_root_password
MYSQL_HOST=mysql_server
MYSQL_PORT=3306

# Redis Configurations
REDIS_HOST=redis_server
REDIS_PORT=6379
