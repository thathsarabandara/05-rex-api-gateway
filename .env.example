APP_NAME=rex-api-gateway
NODE_ENV=development
PORT=8000
LOG_LEVEL=info

REDIS_URL=redis://localhost:6379/3

AUTH_SERVICE_URL=http://rex-auth-service:8000
ROBOT_SERVICE_URL=http://rex-robot-service:8000
NOTIFICATION_SERVICE_URL=http://rex-notification-engine:8000
TELEMETRY_SERVICE_URL=http://rex-telemetry-service:8000
VISION_SERVICE_URL=http://rex-vision-service:8000
EVENT_SERVICE_URL=http://rex-event-engine:8000
VOICE_SERVICE_URL=http://rex-voice-assistant:8000
AGENT_SERVICE_URL=http://rex-agent-runtime:8000
MEMORY_SERVICE_URL=http://rex-memory-engine:8000

USER_JWT_SECRET_KEY=change-me
USER_JWT_ALGORITHM=HS256
USER_JWT_ISSUER=rex-auth-service
USER_JWT_AUDIENCE=rex-platform

ROBOT_JWT_SECRET_KEY=change-me
ROBOT_JWT_ALGORITHM=HS256
ROBOT_JWT_ISSUER=rex-robot-service
ROBOT_JWT_AUDIENCE=rex-device-platform

INTERNAL_SERVICE_TOKEN=change-me

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1,api.rex.example.com

DEFAULT_TIMEOUT_MS=10000
AUTH_TIMEOUT_MS=10000
ROBOT_TIMEOUT_MS=5000
NOTIFICATION_TIMEOUT_MS=10000
TELEMETRY_TIMEOUT_MS=15000
VISION_TIMEOUT_MS=30000
AGENT_TIMEOUT_MS=60000

MAX_JSON_BODY_MB=2
MAX_UPLOAD_BODY_MB=6
MAX_WEBSOCKET_MESSAGE_KB=64

RATE_LIMIT_ENABLED=true

GHCR_IMAGE=ghcr.io/OWNER/05-rex-api-gateway
