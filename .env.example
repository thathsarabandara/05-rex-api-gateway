NODE_ENV=DEVELOPMENT
PORT=9000
LOG_LEVEL=info

AUTH_SERVER_URL=http://rex-auth-server:9001
IDENTITY_SERVER_URL=http://rex-robot-server:9002
NOTIFICATION_SERVICE_URL=http://rex-notification-engine:9008
WEB_DASHBOARD_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

JWT_AUTH_SECRET=
JWT_IDENTITY_SECRET=

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
REQUEST_TIMEOUT=30000

# Central Database Configurations
MYSQL_ROOT_PASSWORD=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_HOST=
MYSQL_PORT=

# Redis Configurations
REDIS_HOST=redis_server
REDIS_PORT=6379

ENV=dev
