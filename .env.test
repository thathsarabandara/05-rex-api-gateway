# ──────────────────────────────────────────────────────────────────────────────
# .env.test — Safe test-only environment variables
# Committed intentionally; all secrets are non-production placeholder values.
# ──────────────────────────────────────────────────────────────────────────────
APP_NAME=rex-api-gateway
NODE_ENV=test
PORT=8000
LOG_LEVEL=silent

REDIS_URL=redis://localhost:6379/3

AUTH_SERVICE_URL=http://127.0.0.1:8001
ROBOT_SERVICE_URL=http://127.0.0.1:8002
NOTIFICATION_SERVICE_URL=http://127.0.0.1:8003
TELEMETRY_SERVICE_URL=http://127.0.0.1:8004
VISION_SERVICE_URL=http://127.0.0.1:8005
EVENT_SERVICE_URL=http://127.0.0.1:8006
VOICE_SERVICE_URL=http://127.0.0.1:8007
AGENT_SERVICE_URL=http://127.0.0.1:8008
MEMORY_SERVICE_URL=http://127.0.0.1:8009

USER_JWT_SECRET_KEY=test-user-jwt-secret-must-be-long-enough-key-value-here
USER_JWT_ALGORITHM=HS256
USER_JWT_ISSUER=rex-auth-service
USER_JWT_AUDIENCE=rex-platform

ROBOT_JWT_SECRET_KEY=test-robot-jwt-secret-must-be-long-enough-key-value-here
ROBOT_JWT_ALGORITHM=HS256
ROBOT_JWT_ISSUER=rex-robot-service
ROBOT_JWT_AUDIENCE=rex-device-platform

INTERNAL_SERVICE_TOKEN=test-internal-service-token

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1

DEFAULT_TIMEOUT_MS=10000
AUTH_TIMEOUT_MS=10000
ROBOT_TIMEOUT_MS=5000
NOTIFICATION_TIMEOUT_MS=10000
TELEMETRY_TIMEOUT_MS=15000
VISION_TIMEOUT_MS=30000
AGENT_TIMEOUT_MS=60000

MAX_JSON_BODY_MB=2
MAX_UPLOAD_BODY_MB=6
MAX_WEBSOCKET_MESSAGE_KB=64

RATE_LIMIT_ENABLED=true
